{
  "name": "musicarr-desktop",
  "version": "1.0.4",
  "description": "Desktop client for a self-hosted Musicarr music server. Connects to a remote Musicarr server and exposes its full web experience in a native window with media-key, tray and multi-server support.",
  "author": "benjamin-decreusefond",
  "license": "MIT",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "lint": "node --check src/main.js && node --check src/preload.js && node --check src/titlebar-preload.js && node --check src/settings-preload.js && node --check src/menu.js && node --check src/store.js && node --check src/updater.js && node --check src/renderer/connect.js && node --check src/renderer/titlebar.js && node --check src/renderer/settings.js",
    "icons": "node build/generate-icons.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ovh.bigbossben.musicarr.desktop",
    "productName": "Musicarr",
    "copyright": "Copyright © 2026 benjamin-decreusefond",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "benjamin-decreusefond",
        "repo": "Musicarr-desktop"
      }
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Musicarr-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Musicarr"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
